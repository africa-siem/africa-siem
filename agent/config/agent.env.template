# ============================================================================
# SIEM Africa — Module 3 (Agent) — Configuration
# ============================================================================
# Fichier : /etc/siem-africa/agent.env
# Permissions : 640, propriétaire root:siem-africa
#
# Ce fichier est créé automatiquement par install_agent.sh.
# Les paramètres marqués [BDD] peuvent aussi être modifiés via la table
# settings de la BDD, qui prend le pas sur cette config (rechargement
# possible via SIGHUP : kill -HUP $(cat /var/run/siem-africa-agent.pid))
# ============================================================================


# ----------------------------------------------------------------------------
# CHEMINS SYSTÈME
# ----------------------------------------------------------------------------
DB_PATH=/var/lib/siem-africa/siem.db
ALERTS_JSON=/var/ossec/logs/alerts/alerts.json
LOG_FILE=/var/log/siem-africa/agent.log
PID_FILE=/var/run/siem-africa-agent.pid


# ----------------------------------------------------------------------------
# COMPORTEMENT GÉNÉRAL
# ----------------------------------------------------------------------------
# Intervalle de polling de alerts.json (en secondes)
POLLING_INTERVAL_SEC=5

# Nombre max d'alertes traitées par cycle (anti-flood)
BATCH_SIZE=100

# Niveau de log : DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Langue par défaut (fr / en) [BDD]
LANG=fr


# ----------------------------------------------------------------------------
# CORRÉLATION DES ALERTES
# ----------------------------------------------------------------------------
# Fenêtre de corrélation (secondes) : alertes identiques dans cette
# fenêtre sont mergées en une seule
CORRELATION_WINDOW_SEC=60
CORRELATION_THRESHOLD=3


# ----------------------------------------------------------------------------
# ACTIVE RESPONSE (blocage iptables automatique)
# ----------------------------------------------------------------------------
# Active Response activé ? [BDD]
ACTIVE_RESPONSE_ENABLED=1

# Délai avant blocage effectif (secondes). Permet à l'admin
# d'annuler manuellement avant exécution.
ACTIVE_RESPONSE_DELAY_SEC=300

# Durée du blocage iptables (secondes). 3600 = 1 heure
ACTIVE_RESPONSE_DURATION_SEC=3600


# ----------------------------------------------------------------------------
# HONEYPOTS
# ----------------------------------------------------------------------------
# Honeypots activés ? [BDD]
HONEYPOT_ENABLED=1

# Ports d'écoute des faux services
HONEYPOT_SSH_PORT=2222
HONEYPOT_HTTP_PORT=8888
HONEYPOT_MYSQL_PORT=3307

# Durée du blocage automatique d'une IP qui touche un honeypot (secondes)
HONEYPOT_AUTO_BLOCK_DURATION_SEC=3600


# ----------------------------------------------------------------------------
# IA OLLAMA (explications automatiques)
# ----------------------------------------------------------------------------
# IA activée ? [BDD]
AI_ENABLED=1

# Provider : ollama / disabled
AI_PROVIDER=ollama

# URL Ollama (par défaut : local)
AI_OLLAMA_URL=http://localhost:11434

# Modèle utilisé (LLaMA 3.2 3B = compromis qualité/RAM idéal pour PME) [BDD]
AI_OLLAMA_MODEL=llama3.2:3b

# Timeout d'inférence (secondes)
AI_TIMEOUT_SEC=30

# Mise en cache des explications (évite ré-inférence pour alertes identiques)
AI_CACHE_ENABLED=1


# ----------------------------------------------------------------------------
# BRUIT-KILLER (Mécanisme 3 du CDC)
# ----------------------------------------------------------------------------
# Seuil d'alertes par signature/IP au-delà duquel un filtre auto est créé [BDD]
NOISE_KILLER_THRESHOLD=100

# Fenêtre de détection en heures [BDD]
NOISE_KILLER_WINDOW_HOURS=1

# Durée du filtre temporaire généré (heures)
NOISE_KILLER_FILTER_DURATION_HOURS=24


# ----------------------------------------------------------------------------
# SMTP (notifications email)
# ----------------------------------------------------------------------------
# Serveur SMTP. Pour Gmail : smtp.gmail.com:587 avec TLS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Identifiants SMTP (Gmail : app password requis, PAS le mot de passe normal)
# Voir : https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASSWORD=

# Utiliser TLS (recommandé)
SMTP_USE_TLS=1

# Adresse "From" des emails envoyés
SMTP_FROM=siem-africa@localhost


# ----------------------------------------------------------------------------
# NOTIFICATIONS
# ----------------------------------------------------------------------------
# Email destinataire des alertes (séparer par virgule pour plusieurs) [BDD]
ALERT_EMAIL=

# Anti-spam : ne pas envoyer plus d'1 email pour la même alerte récurrente
# pendant cette fenêtre (en minutes) [BDD]
EMAIL_DEDUP_WINDOW_MIN=15

# Sévérité minimum pour déclencher un email :
# INFO / LOW / MEDIUM / HIGH / CRITICAL [BDD]
MIN_SEVERITY_FOR_EMAIL=HIGH


# ----------------------------------------------------------------------------
# SERVEUR / DASHBOARD
# ----------------------------------------------------------------------------
# IP publique du serveur SIEM (pour les liens dans les emails)
SERVER_IP=127.0.0.1

# URL du dashboard (Module 4)
DASHBOARD_URL=http://127.0.0.1:8000
